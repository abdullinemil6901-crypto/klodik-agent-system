# Конфигурация доставки в Telegram — шаблон.
#
# Рабочую копию держать ВНЕ репозитория, например:
#   cp scripts/telegram.env.example ~/.klodik/telegram.env
#   chmod 600 ~/.klodik/telegram.env
# Скрипт подхватывает её через --env-file; переменные окружения имеют приоритет.

# Токен бота: создать бота у @BotFather (/newbot), скопировать токен.
TELEGRAM_BOT_TOKEN=

# ID чата — можно оставить пустым: интерактивный бот (scripts/telegram_bot.py)
# привяжет чат сам по первому /start, и digest-скрипт подхватит привязку.
# Вручную: https://api.telegram.org/bot<ТОКЕН>/getUpdates → message.chat.id.
TELEGRAM_CHAT_ID=

# Защита привязки (рекомендуется хотя бы одно). Без них владельцем становится
# первый, кто нашёл бота и нажал /start.
# TELEGRAM_OWNER_ID — привязка разрешена только из этого чата (свой user id).
# TELEGRAM_BIND_SECRET — привязка только по «/start <секрет>»
#   (удобно ссылкой: t.me/<имя_бота>?start=<секрет>).
# TELEGRAM_OWNER_ID=
# TELEGRAM_BIND_SECRET=

# Необязательные параметры (значения по умолчанию).
# TELEGRAM_TIMEOUT_SEC=10
# TELEGRAM_RETRIES=3
