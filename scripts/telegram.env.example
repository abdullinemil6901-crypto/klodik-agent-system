# Конфигурация доставки в Telegram — шаблон.
#
# Рабочую копию держать ВНЕ репозитория, например:
#   cp scripts/telegram.env.example ~/.klodik/telegram.env
#   chmod 600 ~/.klodik/telegram.env
# Скрипт подхватывает её через --env-file; переменные окружения имеют приоритет.

# Токен бота: создать бота у @BotFather (/newbot), скопировать токен.
TELEGRAM_BOT_TOKEN=

# ID чата: написать своему боту любое сообщение, затем открыть
# https://api.telegram.org/bot<ТОКЕН>/getUpdates и взять message.chat.id.
TELEGRAM_CHAT_ID=

# Необязательные параметры (значения по умолчанию).
# TELEGRAM_TIMEOUT_SEC=10
# TELEGRAM_RETRIES=3
